# Worker Dockerfile - Redis Queue Worker
FROM python:3.13-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY pyproject.toml uv.lock ./

# Install uv for dependency management
RUN pip install uv

# Install dependencies including RQ (Redis Queue)
RUN uv sync --frozen

# Copy the source code
COPY src/ ./src/
COPY config.ini ./

# Create logs directory
RUN mkdir -p /app/logs

# Set Python path to include src directory
ENV PYTHONPATH=/app/src

# Set Redis connection environment variables
ENV REDIS_HOST=redis
ENV REDIS_PORT=6379
ENV REDIS_DB=0

# Run the RQ worker to process jobs from Redis queue
CMD ["uv", "run", "python", "-m", "winter_dragon.workers"]
